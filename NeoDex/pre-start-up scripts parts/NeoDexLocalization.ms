/*
	NeoDexLocalization.ms
	=====================
	Central localization file for the NeoDex Toolkit.
	
	Supported languages: English (en), Chinese (zh), German (de), Russian (ru), Japanese (ja), Korean (ko)
	
	HOW IT WORKS:
	  - Each language has its own data section with #("key", "translated text")
	  - The code uses ::L.t "key" to get the text in the active language
	  - If the translated text is "" (empty), it falls back to English
	  - On startup, the system auto-detects the language from 3ds Max locale
	  - The user can manually switch via Settings menu or ::L.setLanguage "de"
	  - The choice is saved in NeoDex_Settings.ini
	
	HOW TO TRANSLATE:
	  Find your language section and fill in the translations.
	  Leave "" for entries you haven't translated yet - they show English.
	
	HOW TO ADD A NEW LANGUAGE:
	  1. Add a new data section (copy enData, rename to xxData)
	  2. Add "xx" to supportedLanguages array
	  3. Add xxDict declaration and loading in loadTranslations
	  4. Add "xx" case to t() function and detectMaxLanguage()
	  5. Add display name to Settings.mcr dropdown
	
	HOW TO ADD A NEW STRING:
	  1. Add #("mymodule_my_label", "My Label") to enData
	  2. Add #("mymodule_my_label", "翻译") to zhData (and other languages)
	  3. Use in code: ::L.t "mymodule_my_label"
	
	Load Order: After NeoDexGlobals.ms, before all UI scripts.
*/

struct NeoDexLocalizationStruct
(
	public currentLanguage = "en",
	public supportedLanguages = #("en", "zh", "de", "ru", "ja", "ko"),
	
	-- Internal storage
	private enDict = Dictionary #string,
	private zhDict = Dictionary #string,
	private deDict = Dictionary #string,
	private ruDict = Dictionary #string,
	private jaDict = Dictionary #string,
	private koDict = Dictionary #string,
	private iniPath = "",
	
	-- ====================================================================
	-- PUBLIC API
	-- ====================================================================
	
	-- Get translated string for current language. Falls back to English.
	public fn t key =
	(
		local dict = undefined
		case this.currentLanguage of
		(
			"zh": dict = this.zhDict
			"de": dict = this.deDict
			"ru": dict = this.ruDict
			"ja": dict = this.jaDict
			"ko": dict = this.koDict
		)
		if dict != undefined then
		(
			if hasDictValue dict key then
			(
				local val = dict[key]
				if val != "" then return val
			)
		)
		-- Fallback to English
		if hasDictValue this.enDict key then
			return this.enDict[key]
		-- Last resort: return key name (helps spot missing entries)
		key
	),
	
	-- Switch language ("en", "zh", "de", "ru", "ja", or "ko")
	public fn setLanguage lang =
	(
		lang = toLower lang
		if findItem this.supportedLanguages lang == 0 then
		(
			format "NeoDex L10n: '%' not supported\n" lang
			return false
		)
		this.currentLanguage = lang
		if this.iniPath != "" then
			setINISetting this.iniPath "Localization" "Language" lang
		format "NeoDex L10n: set to '%'\n" lang
		true
	),
	
	public fn getLanguage = this.currentLanguage,
	public fn getAvailableLanguages = this.supportedLanguages,
	
	-- ====================================================================
	-- AUTO-DETECTION
	-- ====================================================================
	
	public fn detectMaxLanguage =
	(
		local detected = "en"
		try (
			-- Check system locale via .NET
			local ci = (dotNetClass "System.Globalization.CultureInfo").CurrentUICulture
			local lang2 = toLower ci.TwoLetterISOLanguageName
			if lang2 == "zh" then return "zh"
			if lang2 == "de" then return "de"
			if lang2 == "ru" then return "ru"
			if lang2 == "ja" then return "ja"
			if lang2 == "ko" then return "ko"
			-- Check userscripts path for Chinese subfolder
			local p = toUpper (getDir #userscripts)
			if (findString p "\\CHS") != undefined or (findString p "\\ZH-CN") != undefined then
				return "zh"
			-- Check maxroot path
			p = toUpper (getDir #maxroot)
			if (findString p "\\CHS") != undefined or (findString p "\\ZH-CN") != undefined then
				return "zh"
		) catch ()
		detected
	),
	
